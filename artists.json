      },
      "photo": "artists/photos/chevy-beaulieu.jpg",
      "featured": true,
      "awards": [
        "3× Indigenous Music Countdown #1",
        "2022 CMAB Fans' Choice nominee"
      ]
    },
    {
      "id": "ava-rose-johnson",
      "name": "Ava Rose Johnson",
      "name_normalized": "ava rose johnson",
      "nation": "Osage & Cherokee",
      "hometown": "Eufaula, Oklahoma",
      "based_in": "Oklahoma / Nashville",
      "genre": [
        "country",
        "americana"
      ],
      "active_since": "2017",
      "bio": "Ava Rose Johnson is an Osage and Cherokee singer-songwriter from Oklahoma who made history at age 12 as the youngest person ever to win a Native American Music Award. Now a Nashville recording artist and 2025 Recording Academy / GRAMMYs new member, she's racked up four top-10 singles on the Indigenous Music Countdown — including Oklahoma Sky, which hit #1 in 2025. She's performed the National Anthem at multiple OKC Thunder games, the NCAA Women's College World Series, and on Good Morning America.",
      "kbwt_note": "Started writing at age 12 and never slowed down. Oklahoma Sky has Osage references right in the lyrics.",
      "tracks_in_rotation": [
        "Oklahoma Sky"
      ],
      "links": {
        "website": "https://www.avarosejohnsonmusic.com",
