    {
      "id": "brothers-wilde",
      "name": "Brothers Wilde",
      "name_normalized": "brothers wilde",
      "nation": "Anishinaabe (Kettle and Stony Point First Nation)",
      "hometown": "Kettle and Stony Point First Nation, Ontario",
      "based_in": "Ontario",
      "genre": [
        "country",
        "country rock",
        "roots"
      ],
      "active_since": "2018",
      "bio": "Brothers Wilde are a country-rock duo of siblings Nolan and Ethan Wilde from Kettle and Stony Point First Nation, northeast of Sarnia, Ontario. Lead singer Nolan and lead guitarist Ethan blend country twang with classic rock and roll licks — earning them two #1 singles on the Indigenous Music Countdown (2022 and 2025), plus the 2025 FCLMA Songwriters of the Year award and 2024 FCLMA Country Artist of the Year. As Ethan put it: \"We're not afraid to show that we're country guys, too. We're Indigenous, and we're country.\" They want to be the kind of artists young Indigenous songwriters can look at and say, \"if they can do it, maybe I can do it too.\"",
      "kbwt_note": "Brothers from a Three Fires Confederacy nation — Anishinaabe relatives doing big things.",
      "tracks_in_rotation": [
        "I Hold On",
        "Buzzin"
      ],
      "links": {
        "website": "https://www.brotherswildemusic.com",
        "facebook": "https://www.facebook.com/brotherswildemusic",
        "instagram": "https://www.instagram.com/brotherswildemusic",
        "youtube": "https://www.youtube.com/@brotherswilde9548",
        "apple": "https://music.apple.com/ca/artist/brothers-wilde/1514538119"
      },
      "photo": "artists/photos/brothers-wilde.jpg",
      "featured": true,
      "awards": [
        "2× Indigenous Music Countdown #1 (2022, 2025)",
        "2025 FCLMA Songwriters of the Year",
        "2024 FCLMA Country Artist of the Year",
        "2019 NACMAI New Country Duo of the Year"
      ]
    },
    {
      "id": "catie-st-germain",
      "name": "Catie St.Germain",
      "name_normalized": "catie st germain",
      "alt_names": [
