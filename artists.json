      "nation": "Métis (Red River)",
      "hometown": "Niverville, Manitoba",
      "based_in": "Niverville, Manitoba",
      "genre": [
        "country"
      ],
      "active_since": "2023",
      "bio": "Catie St. Germain is a Métis country artist from Niverville, Manitoba who broke through in 2023 with the Manitoba Country Music Association's Emerging Artist award and hasn't slowed down. Her debut EP Cleaning House (Or Trying) earned her three more MCMAs in 2024, and her 2025 single Good Girl Gone Bad Mom — born out of a real conversation about everything moms juggle in a day — became a fan favorite that earned her six MCMA nominations including Female Artist of the Year and the NCI FM Indigenous Country Music Award. She delivered the national anthem at the 112th Grey Cup in November 2025.",
      "kbwt_note": "Sang O Canada at the Grey Cup. A Métis country artist on the rise — and the song hits home for any mom in the audience.",
      "tracks_in_rotation": [
        "Good Girl Gone Bad Mom"
      ],
      "links": {
        "website": "https://www.catiestgermain.com",
        "facebook": "https://www.facebook.com/CatieStGermainBand",
