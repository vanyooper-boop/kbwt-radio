    {
      "id": "ali-fontaine",
      "name": "Ali Fontaine",
      "name_normalized": "ali fontaine",
      "nation": "Sagkeeng Anishinaabe",
      "hometown": "Sagkeeng First Nation, Manitoba",
      "based_in": "Saskatoon, Saskatchewan",
      "genre": [
        "country",
        "folk",
        "r&b"
      ],
      "active_since": "2010",
      "bio": "Ali Fontaine is a multi-award-winning Anishinaabe singer-songwriter who grew up in Sagkeeng First Nation, Manitoba. She first gained attention at 15 when she won a talent competition that earned her studio time, and released her debut album before finishing high school — earning Best Country Recording at the 2013 Native American Music Awards. A four-time winner at the Aboriginal Peoples Choice Music Awards, Ali is also a law student at the University of Saskatchewan, advocating for Indigenous peoples and especially for Indigenous women and children. Her recent single Nibi — Anishinaabemowin for water — reflects on Anishinaabe water teachings and the violence against Indigenous women and girls on Turtle Island.",
      "kbwt_note": "Nibi means 'water' in Anishinaabemowin — the same language spoken here at Bahweting.",
      "tracks_in_rotation": [
        "Nibi"
      ],
      "links": {
        "website": "",
        "facebook": "https://www.facebook.com/alifontainemusic",
        "instagram": "https://www.instagram.com/alifontainemusic",
        "spotify": "",
        "apple": ""
      },
      "photo": "artists/photos/ali-fontaine.jpg",
      "featured": true,
      "awards": [
        "2013 Native American Music Awards — Best Country Recording",
        "2013 Indigenous Music Awards — Indigenous Female Entertainer of the Year",
        "2011 Aboriginal Peoples Choice Music Awards — Best New Artist & Best Country CD"
      ]
    },
    {
      "id": "chevy-beaulieu",
      "name": "Chevy Beaulieu",
      "name_normalized": "chevy beaulieu",
      "nation": "Indigenous (Canadian)",
      "hometown": "Steen River, Alberta",
      "based_in": "Airdrie, Alberta",
      "genre": [
        "country"
      ],
      "active_since": "2010s",
      "bio": "Chevy Beaulieu is a small-town country artist from Steen River, Alberta — the son of a three-time Canadian Fiddle Champion and raised on Merle Haggard records. Now based in Airdrie and signed to 604 Records, he's worked as a plant operator while building a country music career that includes six radio singles, three #1s on the Indigenous Music Countdown, and a 2022 CMAB Fans' Choice nomination. His 2025 label debut If We Want To was named Stingray's New Country Trending Track and racked up over 200,000 streams in its first weeks.",
      "kbwt_note": "Working musician with day-job roots — the kind of country we like to play.",
      "tracks_in_rotation": [
        "If We Want To"
      ],
      "links": {
        "website": "https://www.604records.com/artist/chevy-beaulieu/",
